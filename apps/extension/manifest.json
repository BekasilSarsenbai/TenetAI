{
  "manifest_version": 3,
  "name": "Tenet — record & summarize calls",
  "version": "0.4.7",
  "description": "Record any call from your browser tab — no bot joins. Get an AI transcript and summary linked to the exact second.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "offscreen",
    "storage"
  ],
  "host_permissions": [
    "https://app.tenet.blog/*",
    "https://texgkhxosinhasstxpxk.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Tenet",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}