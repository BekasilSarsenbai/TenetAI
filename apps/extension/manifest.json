{
  "manifest_version": 3,
  "name": "Tenet — record & summarize calls",
  "version": "0.2.2",
  "description": "Record any call from your browser tab — no bot joins. Get an AI transcript and summary linked to the exact second.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "offscreen",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://app.tenet.blog/*",
    "https://texgkhxosinhasstxpxk.supabase.co/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Tenet"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}